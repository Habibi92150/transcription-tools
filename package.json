{
  "name": "transcription-tools",
  "private": true,
  "scripts": {
    "serve:front": "npx serve .",
    "start:backend": "node backend/server.js",
    "dev:backend": "nodemon backend/server.js"
  },
  "nodemonConfig": {
    "watch": [
      "backend"
    ],
    "ext": "js,json,env",
    "ignore": [
      "backend/users.json",
      "backend/**/tmp/**"
    ]
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.6",
    "@ffmpeg/ffmpeg": "0.12.10",
    "@ffmpeg/util": "0.12.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "stripe": "^22.0.1",
    "wav-decoder": "^1.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
