PORT=8787
MAX_FILE_MB=10240

# Premium
PREMIUM_PIN=CHANGE_ME
PREMIUM_SECRET=CHANGE_ME_32_CHARS_RANDOM_STRING

# STT: whisper-cpp | groq | gemini | deepgram
STT_ENGINE=whisper-cpp

# Deepgram (premium — intégration en cours)
DEEPGRAM_API_KEY=
DEEPGRAM_API_BASE=https://api.deepgram.com/v1
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_TIMEOUT_MS=600000

# Groq (STT + cleanup)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_TEMPERATURE=0
GROQ_STT_TIMEOUT_MS=600000
GROQ_CLEANUP_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=60000
GROQ_CONTEXT_WINDOW=5
GROQ_GLOBAL_CONTEXT_CHARS=1800
GROQ_CLEANUP_HINTS=Blaise Matuidi,Coupe du monde,équipe de France

# Gemini (STT + cleanup)
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CLEANUP_MODEL=gemini-2.5-flash
GEMINI_CLEANUP_TEMPERATURE=0
GEMINI_TIMEOUT_MS=60000

# Cleanup texte: none | groq | gemini
TEXT_CLEANUP_PROVIDER=none

# Whisper.cpp (fallback local)
WHISPER_CPP_BIN=backend/bin/whispercpp/Release/whisper-cli.exe
WHISPER_MODEL_PATH=backend/models/ggml-base.bin
WHISPER_LANGUAGE=fr
WHISPER_BEAM_SIZE=8
WHISPER_BEST_OF=8

# Conversion audio WAV (pour Gemini STT)
FFMPEG_BIN=ffmpeg
