PORT=8787
# Pour diariser MP3/MP4/M4A : ffmpeg doit etre dans le PATH (ou chemin absolu ici)
FFMPEG_BIN=ffmpeg
DIARIZATION_PROVIDER=local
DIARIZER_URL=http://127.0.0.1:8790
DIARIZER_API_KEY=
DIARIZER_TIMEOUT_MS=180000
HF_TOKEN=
# STT: whisper-cpp | groq | gemini
# groq/whisper = timings alignés sur l'audio (recommandé pour .srt précis).
# gemini = timestamps estimés par le LLM (TC souvent faux ; texte parfois paraphrasé).
STT_ENGINE=whisper-cpp
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_TEMPERATURE=0
GROQ_STT_TIMEOUT_MS=600000
TEXT_CLEANUP_PROVIDER=none
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CLEANUP_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=60000
GROQ_CONTEXT_WINDOW=5
GROQ_GLOBAL_CONTEXT_CHARS=1800
GROQ_CLEANUP_HINTS=Blaise Matuidi, Coupe du monde, équipe de France
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARY_TEMPERATURE=0.2
# Résumé épisode (/api/episode-summary): groq (défaut) ou gemini (Google AI Studio / clé API Gemini)
SUMMARY_PROVIDER=groq
GEMINI_API_KEY=
# Modèle pour STT audio (generateContent) — distinct de GEMINI_SUMMARY_MODEL si besoin
# Gemini (résumé épisode / STT optionnel) — défaut 2.5 flash ; preview 3 si tu acceptes latence + TC approximatifs en STT
GEMINI_MODEL=gemini-2.5-flash
# Passe audio uniquement pour GEMINI_DIARIZATION_OVERLAY=1 (speakers) — défaut = GEMINI_MODEL
# Ex. gemini-3-flash-preview | gemini-3.1-flash-lite-preview
# GEMINI_DIARIZATION_MODEL=gemini-3-flash-preview
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_TEMPERATURE=0.2
GEMINI_TIMEOUT_MS=60000
GEMINI_CLEANUP_MODEL=gemini-2.5-flash
GEMINI_CLEANUP_TEMPERATURE=0
# Overlay optionnel: conserve les timecodes STT (groq/whisper) mais prend les speakers de Gemini.
# Requiert GEMINI_API_KEY et ajoute un appel Gemini supplementaire.
GEMINI_DIARIZATION_OVERLAY=0
# Préserve les locuteurs rares pendant l'overlay (utile si 3+ intervenants).
GEMINI_OVERLAY_MIN_SPEAKER_SEC=0.7
GEMINI_OVERLAY_MIN_SPEAKER_SEGMENTS=1
GEMINI_OVERLAY_SMOOTHING_CONFIDENCE=0.4
# Exemple test Gemini STT :
# STT_ENGINE=gemini
# DIARIZATION_PROVIDER=local
# TEXT_CLEANUP_PROVIDER=none
SUMMARY_CHUNK_TARGET_CHARS=12000
SUMMARY_MAX_CHUNKS=24
WHISPER_CPP_BIN=backend/bin/whispercpp/Release/whisper-cli.exe
WHISPER_MODEL_PATH=backend/models/ggml-base.bin
WHISPER_LANGUAGE=fr
DIARIZATION_MAX_SPEAKERS=2
DIARIZATION_MIN_GAP_SEC=1.8
DIARIZATION_MIN_TURN_SEC=10
DIARIZATION_MIN_TURN_SEGMENTS=4
DIARIZATION_SWITCH_COOLDOWN_SEC=6
DIARIZATION_MIN_FEATURE_SEC=0.7
DIARIZATION_MIN_CLUSTER_SEGMENTS=3
DIARIZATION_VOICE_DISTANCE_THRESHOLD=0.85
DIARIZATION_FRAME_SEC=0.9
DIARIZATION_HOP_SEC=0.35
DIARIZATION_CONTINUITY_BONUS=0.2
WHISPER_BEAM_SIZE=8
WHISPER_BEST_OF=8
# ~10 Go (10240 MiB) — aligner nginx client_max_body_size en prod
MAX_FILE_MB=10240