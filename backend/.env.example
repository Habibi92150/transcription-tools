PORT=8787
MAX_FILE_MB=10240

# Firebase Admin (une des deux options)
# — Recommandé : fichier JSON non versionné
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# — Ou JSON minifié sur une seule ligne dans .env (multiline = parse invalide)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Auth JWT — à changer absolument en prod (chaîne aléatoire longue)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_32_CHARS_MIN

# Gemini STT (obligatoire)
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=300000
GEMINI_STT_MAX_OUTPUT_TOKENS=8192
GEMINI_CHUNK_DURATION_SEC=50
GEMINI_CHUNK_OVERLAP_SEC=0

# URL publique du backend (optionnel, pour config frontend auto)
BACKEND_URL=

# Mail de bienvenue — SMTP (optionnel, désactivé si absent)
# Gmail : crée un "mot de passe d'application" sur myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ton@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=SMM Studio <ton@gmail.com>
APP_NAME=SMM Studio
APP_URL=http://localhost:3000

# Conversion audio (ffmpeg requis)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
