PORT=8787
MAX_FILE_MB=10240

# Auth JWT — à changer absolument en prod (chaîne aléatoire longue)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_32_CHARS_MIN

# Gemini STT (obligatoire)
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=300000
GEMINI_STT_MAX_OUTPUT_TOKENS=8192
GEMINI_CHUNK_DURATION_SEC=50
GEMINI_CHUNK_OVERLAP_SEC=0

# URL publique du backend (optionnel, pour config frontend auto)
BACKEND_URL=

# Conversion audio (ffmpeg requis)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
